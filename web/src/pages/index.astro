---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import LeaderboardHome from "../components/LeaderboardHome.astro";
import TarotHome from "../components/TarotHome.astro";
import { getLeaderboardSummary, hasDatabaseBinding, listLeaderboard } from "../lib/db";
import { listTarotCards } from "../lib/tarot";
import type { LeaderboardSortDirection, LeaderboardSortKey } from "../lib/types";

const sortValue = Astro.url.searchParams.get("sort");
const directionValue = Astro.url.searchParams.get("dir");
const tarotPreview = Astro.url.searchParams.get("view") === "tarot";
const isTarotHost = Astro.url.hostname === "taluo.sbai.uk" || tarotPreview;
const submittedState = Astro.url.searchParams.get("state") === "submitted";
const submittedRankValue = Number(Astro.url.searchParams.get("rank"));
const submittedRank = Number.isFinite(submittedRankValue) && submittedRankValue > 0
  ? Math.trunc(submittedRankValue)
  : 0;
const sortKey: LeaderboardSortKey =
  sortValue === "tokens" || sortValue === "sbai" || sortValue === "updatedAt"
    ? sortValue
    : "profanityCount";
const sortDirection: LeaderboardSortDirection = directionValue === "asc" ? "asc" : "desc";

const tarotCards = isTarotHost ? await listTarotCards() : [];
const databaseReady = !isTarotHost && hasDatabaseBinding();
const entries = databaseReady ? await listLeaderboard(50, sortKey, sortDirection) : [];
const summary = databaseReady
  ? await getLeaderboardSummary()
  : {
      participants: 0,
      totalEvents: 0,
      totalTokens: 0,
      averageSbai: 0,
    };

const stats = [
  { label: "Participants", value: summary.participants.toLocaleString("en-US"), tone: "red" as const },
  { label: "Average SBAI", value: summary.averageSbai.toFixed(3), tone: "teal" as const },
  { label: "Uploaded Tokens", value: summary.totalTokens.toLocaleString("en-US"), tone: "gold" as const },
];
---

<BaseLayout
  title={isTarotHost ? "AI Tarot" : "maleme leaderboard"}
  description={isTarotHost ? "AI Tarot of bad agent habits" : "maleme leaderboard"}
  lang="zh-CN"
>
  {
    isTarotHost ? (
      <TarotHome cards={tarotCards} />
    ) : (
      <LeaderboardHome
        entries={entries}
        sortKey={sortKey}
        sortDirection={sortDirection}
        stats={stats}
        submittedState={submittedState}
        submittedRank={submittedRank}
      />
    )
  }
</BaseLayout>
