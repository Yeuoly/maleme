---
import type { CollectionEntry } from "astro:content";
import SiteHeader from "./SiteHeader.astro";
import { getI18n, type Locale } from "../lib/i18n";
import { getTarotCardCopy } from "../lib/tarot";

type Props = {
  cards: CollectionEntry<"tarot">[];
  locale: Locale;
};

const { locale } = Astro.props;
const t = getI18n(locale);
const cards = [...Astro.props.cards].sort((left, right) => left.data.order - right.data.order);
const initialCard = cards[0];
const initialCopy = getTarotCardCopy(initialCard, locale);
const cardsJson = JSON.stringify(
  cards.map((card) => ({
    slug: card.id,
    ...getTarotCardCopy(card, locale),
  })),
).replaceAll("</", "<\\/");
---

<main class="tarot-shell">
  <div class="shell">
    <SiteHeader
      active="tarot"
      title={t.tarot.brandTitle}
      subtitle={t.tarot.brandSubtitle}
      locale={locale}
    />

    <section class="stage surface" id="draw-stage">
      <div class="stage-copy">
        <div class="hero-kicker">{t.tarot.kicker}</div>
        <h1 class="hero-title">{t.tarot.heroTitle}</h1>
        <p class="hero-copy">{t.tarot.heroCopy}</p>
      </div>

      <div class="draw-experience">
        <div class="draw-orbit" id="draw-orbit">
          <button type="button" class="draw-card" id="draw-button" aria-label={t.tarot.drawButton}>
            <span class="draw-card-rotor">
              <span class="draw-card-face draw-card-front">
                <span class="draw-card-code">M</span>
                <span class="draw-card-title">{t.tarot.cardFaceLabel}</span>
                <span class="draw-card-hint">{t.tarot.cardFaceHint}</span>
              </span>

              <span class="draw-card-face draw-card-back">
                <span class="draw-result-label">{t.tarot.resultLabel}</span>
                <span class="draw-result-code" id="draw-result-code">{initialCopy.code}</span>
                <span class="draw-result-title" id="draw-result-title">{initialCopy.title}</span>
                <span class="draw-result-omen" id="draw-result-omen">{initialCopy.omen}</span>
              </span>
            </span>
          </button>

          <div class="draw-actions" id="draw-actions">
            <a class="open-card" id="open-card" href={`/cards/${initialCard.id}`}>{t.tarot.openCard}</a>
            <button type="button" class="draw-again" id="draw-again">{t.tarot.drawAgain}</button>
          </div>
        </div>
      </div>

      <div class="focus-wash" aria-hidden="true"></div>
    </section>
  </div>
</main>

<script define:vars={{ cardsJson }}>
  const cards = JSON.parse(cardsJson);
  const stage = document.getElementById("draw-stage");
  const orbit = document.getElementById("draw-orbit");
  const drawButton = document.getElementById("draw-button");
  const drawAgainButton = document.getElementById("draw-again");
  const openCard = document.getElementById("open-card");
  const resultCode = document.getElementById("draw-result-code");
  const resultTitle = document.getElementById("draw-result-title");
  const resultOmen = document.getElementById("draw-result-omen");
  let busy = false;

  function paint(card) {
    openCard.href = `/cards/${card.slug}`;
    resultCode.textContent = card.code;
    resultTitle.textContent = card.title;
    resultOmen.textContent = card.omen;
  }

  function pickCard() {
    return cards[Math.floor(Math.random() * cards.length)];
  }

  function moveOrbitToCenter() {
    const rect = orbit.getBoundingClientRect();
    orbit.style.setProperty("--orbit-start-x", `${rect.left + rect.width / 2 - window.innerWidth / 2}px`);
    orbit.style.setProperty("--orbit-start-y", `${rect.top + rect.height / 2 - window.innerHeight / 2}px`);
    stage.classList.add("is-focused");
    orbit.classList.add("is-floating", "is-animating");
    window.setTimeout(() => {
      orbit.classList.remove("is-animating");
    }, 580);
  }

  function reveal(card) {
    paint(card);
    orbit.classList.add("is-revealed");
    busy = false;
  }

  function drawFromStage() {
    if (busy) {
      return;
    }

    busy = true;
    moveOrbitToCenter();
    const card = pickCard();
    window.setTimeout(() => {
      reveal(card);
    }, 620);
  }

  function redrawAtCenter() {
    if (busy) {
      return;
    }

    busy = true;
    orbit.classList.remove("is-revealed");
    const card = pickCard();
    window.setTimeout(() => {
      reveal(card);
    }, 280);
  }

  drawButton.addEventListener("click", () => {
    if (orbit.classList.contains("is-floating")) {
      return;
    }

    drawFromStage();
  });

  drawAgainButton.addEventListener("click", redrawAtCenter);
</script>

<style>
  .tarot-shell {
    min-height: 100vh;
  }

  .stage {
    position: relative;
    min-height: calc(100vh - 108px);
    padding: 28px;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.78fr);
    gap: 28px;
    align-items: center;
    background:
      radial-gradient(circle at top left, rgba(255, 183, 3, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(255, 91, 97, 0.16), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(250, 252, 255, 0.88));
    overflow: hidden;
  }

  .focus-wash {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.04), rgba(18, 24, 38, 0.08));
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .stage.is-focused .focus-wash {
    opacity: 1;
  }

  .stage-copy {
    display: grid;
    gap: 14px;
    align-content: center;
    transition: opacity 320ms ease, transform 320ms ease, filter 320ms ease;
  }

  .stage.is-focused .stage-copy {
    opacity: 0.14;
    transform: translateX(-20px) scale(0.98);
    filter: blur(8px);
  }

  .hero-kicker {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-title {
    margin: 0;
    font-size: clamp(42px, 6vw, 88px);
    line-height: 0.98;
    max-width: 8ch;
  }

  .hero-copy {
    margin: 0;
    max-width: 34rem;
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.7;
    color: var(--muted);
  }

  .draw-experience {
    display: grid;
    justify-items: center;
    align-content: center;
  }

  .draw-orbit {
    width: min(100%, 360px);
    display: grid;
    justify-items: center;
    gap: 16px;
    z-index: 2;
  }

  .draw-orbit.is-floating {
    position: fixed;
    left: 50%;
    top: 50%;
    width: min(360px, calc(100vw - 40px));
    transform: translate(-50%, -50%);
    z-index: 40;
  }

  .draw-orbit.is-animating {
    animation: orbit-to-center 580ms cubic-bezier(0.2, 0.82, 0.2, 1) forwards;
  }

  .draw-card {
    position: relative;
    width: 100%;
    aspect-ratio: 0.72;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    perspective: 1800px;
  }

  .draw-card::before,
  .draw-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    border: 1px solid rgba(255, 91, 97, 0.18);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(246, 248, 255, 0.86));
    box-shadow: 0 30px 70px rgba(19, 32, 51, 0.14);
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .draw-card::before {
    transform: translate(-14px, 12px) rotate(-6deg);
  }

  .draw-card::after {
    transform: translate(14px, 12px) rotate(7deg);
  }

  .draw-orbit.is-floating .draw-card::before,
  .draw-orbit.is-floating .draw-card::after {
    opacity: 0;
    transform: translate(0, 0) scale(0.98);
  }

  .draw-card-rotor {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transition: transform 860ms cubic-bezier(0.2, 0.72, 0.18, 1);
  }

  .draw-orbit.is-revealed .draw-card-rotor {
    transform: rotateY(180deg);
  }

  .draw-card-face {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 12px;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid rgba(255, 91, 97, 0.24);
    box-shadow: 0 34px 80px rgba(19, 32, 51, 0.16);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .draw-card-front {
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 183, 3, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(249, 251, 255, 0.9));
  }

  .draw-card-back {
    align-content: start;
    justify-items: start;
    gap: 10px;
    text-align: left;
    transform: rotateY(180deg);
    background:
      radial-gradient(circle at top right, rgba(255, 91, 97, 0.16), transparent 26%),
      radial-gradient(circle at bottom left, rgba(255, 183, 3, 0.14), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 251, 255, 0.92));
  }

  .draw-card-code {
    width: 88px;
    height: 88px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(255, 91, 97, 0.14), rgba(255, 183, 3, 0.18));
    color: var(--accent);
    font-size: 42px;
    font-weight: 900;
  }

  .draw-card-title {
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1;
    font-weight: 900;
    text-align: center;
  }

  .draw-card-hint {
    text-align: center;
    color: var(--muted);
    line-height: 1.6;
    max-width: 16rem;
  }

  .draw-result-label {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .draw-result-code {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .draw-result-title {
    font-size: clamp(30px, 3vw, 42px);
    line-height: 0.98;
    font-weight: 900;
  }

  .draw-result-omen {
    color: var(--muted);
    line-height: 1.7;
    font-size: 15px;
  }

  .draw-actions {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    opacity: 0;
    transform: translateY(14px);
    pointer-events: none;
    transition: opacity 240ms ease, transform 240ms ease;
  }

  .draw-orbit.is-revealed .draw-actions {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .open-card,
  .draw-again {
    min-height: 46px;
    border-radius: 8px;
    padding: 0 16px;
    font: inherit;
    font-size: 14px;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .open-card {
    border: 0;
    color: #ffffff;
    background: linear-gradient(135deg, #d62839, #ff5b61);
    box-shadow: 0 16px 28px rgba(214, 40, 57, 0.22);
  }

  .draw-again {
    border: 1px solid var(--border);
    color: var(--text);
    background: rgba(255, 255, 255, 0.88);
    cursor: pointer;
  }

  @keyframes orbit-to-center {
    0% {
      transform: translate(
        calc(-50% + var(--orbit-start-x)),
        calc(-50% + var(--orbit-start-y))
      ) scale(1);
    }

    72% {
      transform: translate(-50%, -50%) scale(1.04);
    }

    100% {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (max-width: 980px) {
    .stage {
      min-height: auto;
      grid-template-columns: 1fr;
      padding: 22px;
    }

    .stage-copy {
      justify-items: center;
      text-align: center;
    }

    .hero-title {
      max-width: none;
      font-size: clamp(34px, 10vw, 58px);
    }

    .draw-orbit.is-floating {
      width: min(340px, calc(100vw - 28px));
    }
  }
</style>
