---
type Props = {
  title: string;
  description: string;
  lang?: string;
};

const { title, description, lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <slot name="head" />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f6f8fb;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --border: #d9e3f0;
        --text: #132033;
        --muted: #5c6b7c;
        --accent: #ff5b61;
        --accent-2: #0fa3b1;
        --accent-3: #ffb703;
        --shadow: 0 24px 60px rgba(19, 32, 51, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255, 183, 3, 0.18), transparent 24%),
          radial-gradient(circle at top right, rgba(15, 163, 177, 0.18), transparent 22%),
          linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
        color: var(--text);
      }

      a {
        color: inherit;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .page {
        min-height: 100vh;
      }

      .shell {
        max-width: 1380px;
        margin: 0 auto;
        padding: 20px;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 16px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand-mark {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--accent), var(--accent-3));
        color: white;
        display: grid;
        place-items: center;
        font-weight: 900;
        box-shadow: var(--shadow);
      }

      .brand-copy {
        display: grid;
        gap: 2px;
      }

      .brand-title {
        font-size: 15px;
        font-weight: 800;
      }

      .brand-subtitle {
        font-size: 12px;
        color: var(--muted);
      }

      .meta-strip {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .chip {
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.76);
        padding: 8px 10px;
        border-radius: 8px;
        font-size: 12px;
        color: var(--muted);
      }

      .content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        gap: 18px;
      }

      .surface {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .section-title {
        margin: 0 0 12px;
        font-size: 19px;
        line-height: 1.15;
      }

      .muted {
        color: var(--muted);
      }

      @media (max-width: 980px) {
        .content-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <slot />
    </div>
  </body>
</html>
